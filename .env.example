# Copy this file to .env only if you need external integrations.
# For the fully local path in this repo, .env is optional.
# Never commit .env to version control.

# Hugging Face token — only needed for gated model downloads.
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Weights & Biases — only needed when privacy.tracking=wandb.
# Create one at https://wandb.ai/authorize
WANDB_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# W&B project name — used only when privacy.tracking=wandb.
WANDB_PROJECT=simcoe-finetune

# OpenAI API key — only needed for openai/* judge or generation workflows.
# Leave unset for the fully local Ollama path.
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
