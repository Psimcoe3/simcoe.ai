# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# Hugging Face token — required to download gated models (e.g. Llama 3).
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Weights & Biases — required for experiment tracking.
# Create one at https://wandb.ai/authorize
WANDB_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# W&B project name — all training runs will be grouped under this project.
WANDB_PROJECT=simcoe-finetune

# OpenAI API key — required for LLM-as-judge evaluation and data generation.
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
